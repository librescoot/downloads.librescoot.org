---
title: LibreScoot Downloads
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="Download the LibreScoot installer, firmware images, and offline map data for your unu Scooter Pro.">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="Download the LibreScoot installer, firmware updates, and offline map data for your unu Scooter Pro.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://downloads.librescoot.org">
    <meta property="og:image" content="https://librescoot.org/images/og-image.png">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="icon" type="image/png" href="https://librescoot.org/images/favicon.png">
    <link rel="stylesheet" href="https://librescoot.org/fonts/fonts.css">
    <link rel="stylesheet" href="https://librescoot.org/style.css">
    <script>
    (function() {
        var t = localStorage.getItem('theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
    })();
    </script>
    <style>
        .header { padding: 1rem 0; }
        .header-inner { display: flex; justify-content: space-between; align-items: center; }
        .header a { color: var(--text-on-dark); text-decoration: none; }
        .header-brand { font-weight: 500; font-size: 1.2rem; display: flex; align-items: center; gap: 0.4rem; }
        .header-brand-text { padding-top: 1px; font-family: var(--font-display); }
        .header-logo { height: 36px; width: auto; }
        .header-links { display: flex; gap: 1.5rem; font-size: 0.9rem; align-items: center; }
        .header-links a { color: var(--text-on-dark-muted); transition: color 0.15s; }
        .header-links a:hover { color: var(--text-on-dark); }
        main { padding: 2.5rem 0 4rem; min-height: calc(100vh - 150px); }
        h1 { font-size: 2.5rem; margin-bottom: 0.35rem; }
        .lead { font-size: 1.05rem; color: var(--text-secondary); margin-bottom: 2.5rem; }
        .section { margin-bottom: 3rem; padding: 0; }
        .section-title { display: flex; align-items: center; gap: 0.5rem; font-size: 1.4rem; font-weight: 400; font-family: var(--font-display); color: var(--text-primary); margin-bottom: 0.4rem; padding-bottom: 0.4rem; border-bottom: 2px solid var(--border-subtle); }
        .section-title svg { width: 22px; height: 22px; color: var(--accent); }
        .section > p { font-size: 0.95rem; margin-bottom: 1rem; }
        .hint { font-size: 0.88rem; color: var(--text-tertiary); margin-bottom: 1rem; }
        .channels { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
        .ch-card { border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); background: var(--bg-card); padding: 0.9rem 1rem; }
        .ch-card.ch-recommended { border-color: var(--accent); border-width: 2px; background: var(--accent-subtle); }
        .ch-card h4 { font-size: 1rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.1rem; display: flex; align-items: center; gap: 0.4rem; }
        .ch-card .ch-rec-badge { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; background: var(--accent); color: white; padding: 0.1rem 0.4rem; border-radius: 3px; }
        .ch-card .ch-desc { font-size: 0.82rem; color: var(--text-tertiary); margin-bottom: 0.4rem; }
        .ch-card .ch-meta { font-size: 0.75rem; color: var(--text-tertiary); margin-bottom: 0.5rem; }
        .ch-assets { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.5rem; }
        .dl-btn { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.35rem 0.7rem; background: var(--accent); color: white; text-decoration: none; border-radius: var(--radius); font-size: 0.82rem; font-weight: 500; transition: background 0.15s; white-space: nowrap; }
        .dl-btn:hover { background: var(--accent-hover); color: white; }
        .dl-btn svg { width: 13px; height: 13px; }
        .dl-btn .dl-size { opacity: 0.75; font-weight: 400; }
        .ch-links { display: flex; gap: 0.75rem; font-size: 0.78rem; }
        .ch-links a { display: inline-flex; align-items: center; gap: 0.2rem; color: var(--accent); text-decoration: none; }
        .ch-links a:hover { color: var(--accent-hover); }
        .ch-links svg { width: 12px; height: 12px; }
        .map-table { border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); overflow: hidden; }
        .map-row { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 0.5rem; padding: 0.35rem 0.9rem; border-bottom: 1px solid var(--border-subtle); }
        .map-row:last-child { border-bottom: none; }
        .map-row:nth-child(even) { background: var(--bg-secondary); }
        .map-name { font-weight: 500; font-size: 0.85rem; color: var(--text-primary); }
        .map-btn { display: inline-flex; align-items: center; gap: 0.2rem; padding: 0.2rem 0.5rem; background: var(--bg-card); color: var(--accent); text-decoration: none; border-radius: var(--radius); font-size: 0.75rem; font-weight: 500; border: 1px solid var(--border-subtle); transition: all 0.15s; white-space: nowrap; }
        .map-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }
        .map-btn svg { width: 12px; height: 12px; }
        .map-source { font-size: 0.78rem; color: var(--text-tertiary); margin-top: 0.6rem; }
        .installer-hero { background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-radius: var(--radius-lg); padding: 1.25rem; }
        .installer-hero p { color: var(--text-secondary); font-size: 0.95rem; margin: 0.5rem 0; }
        .installer-hero p:first-child { margin-top: 0; }
        .beta-note { font-size: 0.88rem; color: var(--yellow); background: var(--yellow-bg); border: 1px solid var(--yellow); border-radius: var(--radius); padding: 0.5rem 0.75rem; margin: 0.75rem 0; }
        .beta-note a { color: var(--yellow); font-weight: 600; }
        .installer-buttons { display: flex; gap: 0.6rem; flex-wrap: wrap; margin: 1rem 0 0.5rem; }
        .installer-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.55rem 1.1rem; background: var(--accent); color: white; text-decoration: none; border-radius: var(--radius); font-weight: 500; font-size: 0.9rem; transition: background 0.15s; }
        .installer-btn:hover { background: var(--accent-hover); color: white; }
        .installer-btn svg { flex-shrink: 0; }
        .installer-meta { font-size: 0.82rem; color: var(--text-tertiary); margin: 0.25rem 0 0; }
        .unsigned-note { font-size: 0.82rem; color: var(--yellow); background: var(--yellow-bg); border: 1px solid var(--yellow); border-radius: var(--radius); padding: 0.5rem 0.75rem; margin: 0.75rem 0 0; }
        .unsigned-note code { font-size: 0.78rem; }
        .footer { padding: 1.5rem 0; font-size: 0.85rem; color: var(--text-on-dark-muted); }
        .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.75rem; }
        .footer strong { color: var(--text-on-dark); font-family: var(--font-display); }
        .footer a { color: var(--text-on-dark-muted); text-decoration: none; }
        .footer a:hover { color: var(--text-on-dark); }
        @media (max-width: 768px) {
            .channels { grid-template-columns: 1fr; }
            .map-row { grid-template-columns: 1fr; gap: 0.35rem; padding: 0.7rem 1rem; }
            .map-name { font-weight: 600; }
            .map-btn { justify-content: center; }
            .header-links { gap: 0.75rem; font-size: 0.82rem; }
            .installer-buttons { flex-direction: column; }
            .installer-btn { justify-content: center; }
        }
        @media (max-width: 480px) {
            .header-inner { flex-direction: column; gap: 0.5rem; }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="container header-inner">
            <a href="https://librescoot.org" class="header-brand"><img src="https://librescoot.org/images/logo-small.png" srcset="https://librescoot.org/images/logo-small@2x.png 2x" alt="LibreScoot" class="header-logo"> <span class="header-brand-text">Downloads</span></a>
            <nav class="header-links">
                <a href="https://librescoot.org/docs/">Docs</a>
                <a href="https://librescoot.org/docs/install.html">Installation</a>
                <a href="https://librescoot.org/docs/architecture.html">Architecture</a>
                <a href="https://librescoot.org/changelog.html">Changelog</a>
                <a href="https://discord.gg/VrumFruSzJ">Discord</a>
                <a href="https://github.com/librescoot">GitHub</a>
                <button class="theme-toggle" aria-label="Toggle theme">
                    <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                    <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                </button>
            </nav>
        </div>
    </header>

    <main>
        <div class="container">
            <h1>Downloads</h1>

            {# ── Installer ── #}
            <div class="section" id="installer">
                <h2 class="section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Installer
                </h2>
                <div class="installer-hero">
                    <p>Desktop app that walks you through installing LibreScoot on your scooter. Downloads firmware, flashes both boards, and sets up offline maps. All you need is a USB cable and a screwdriver.</p>
                    <p class="beta-note">Beta software. While we have tested on all platforms against real hardware, things can still go wrong. In the worst case, your scooter might become inoperable without deeper intervention. Use at your own risk. For support, try <a href="https://discord.gg/VrumFruSzJ">Discord</a>, but keep in mind we're all volunteers.</p>
                    <div class="installer-buttons">
                        {% for asset in installer.assets %}
                            {% set name = asset.name | lower %}
                            {% if "linux" in name and (name.endsWith(".tar.gz") or name.endsWith(".tgz")) %}
                                <a href="{{ asset.url }}" class="installer-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                                    Linux (x64)
                                </a>
                            {% elif "macos" in name and ".dmg" in name %}
                                <a href="{{ asset.url }}" class="installer-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                                    macOS (Universal)
                                </a>
                            {% elif "windows" in name and ".zip" in name %}
                                <a href="{{ asset.url }}" class="installer-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/></svg>
                                    Windows (x64)
                                </a>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <p class="installer-meta">Version {{ installer.version }} (beta) &middot; <a href="https://github.com/librescoot/installer/releases">All releases</a> &middot; <a href="https://github.com/librescoot/installer">Source code</a> &middot; <a href="https://librescoot.org/docs/install.html">Installation guide</a></p>
                    <p class="unsigned-note">The installer is not code-signed. <strong>macOS:</strong> right-click &rarr; Open, or run <code>xattr -cr '/Applications/LibreScoot Installer.app'</code>. <strong>Windows:</strong> click <em>More info</em> &rarr; <em>Run anyway</em>.</p>
                </div>
            </div>

            {# ── Firmware Updates ── #}
            <div class="section">
                <h2 class="section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
                    Firmware Updates
                </h2>
                <p class="hint">To install an update, enable update mode via the display menu, then copy the .mender file over USB. For fresh installations, use the <a href="#installer">installer app</a> above.</p>

                <div class="channels">
                    {% set channels = [
                        { key: "stable", label: "Stable", desc: "Fully tested releases. Not yet available.", rec: false },
                        { key: "testing", label: "Testing", desc: "Recommended channel. New features, tested on real hardware.", rec: true },
                        { key: "nightly", label: "Nightly", desc: "Latest development builds. Recommended for developers only.", rec: false }
                    ] %}
                    {% for ch in channels %}
                        {% set releases = firmware[ch.key] %}
                        {% set r = releases[0] if releases.length else null %}
                        <div class="ch-card{% if ch.rec %} ch-recommended{% endif %}">
                            <h4>{{ ch.label }}{% if ch.rec %} <span class="ch-rec-badge">Recommended</span>{% endif %}</h4>
                            <div class="ch-desc">{{ ch.desc }}</div>
                            {% if r %}
                                <div class="ch-meta">{{ r.tag_name }} &middot; {{ r.published_at | fmtDate }}</div>
                                <div class="ch-assets">
                                    {% for a in r.assets %}
                                        {% if a.name.endsWith(".mender") %}
                                            {% if "-dbc-" in a.name %}
                                                <a href="{{ a.url }}" class="dl-btn">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                                    DBC (Dashboard) <span class="dl-size">{{ a.size | fmt }}</span>
                                                </a>
                                            {% elif "-mdb-" in a.name %}
                                                <a href="{{ a.url }}" class="dl-btn">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                                    MDB (Controller) <span class="dl-size">{{ a.size | fmt }}</span>
                                                </a>
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                </div>
                                <div class="ch-links">
                                    <a href="https://github.com/librescoot/librescoot/releases/tag/{{ r.tag_name }}" target="_blank" rel="noopener">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                                        Release notes
                                    </a>
                                    {% if releases.length > 1 %}
                                        <a href="https://github.com/librescoot/librescoot/releases" target="_blank" rel="noopener">Older releases</a>
                                    {% endif %}
                                </div>
                            {% else %}
                                <div class="ch-meta">No releases yet.</div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# ── Maps ── #}
            <div class="section">
                <h2 class="section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 7 6-3 6 3 6-3v13l-6 3-6-3-6 3Z"/><path d="m9 4v13"/><path d="m15 7v13"/></svg>
                    Map &amp; Routing Data
                </h2>
                {% if maps.updated %}<p class="hint" style="margin-top:-0.2rem">Updated {{ maps.updated | fmtDate }}</p>{% endif %}
                <p>Offline map tiles and turn-by-turn routing data, available per German state. Each one also covers about 20 km of the surrounding area. Download the map and routing files for your state and copy them to the scooter via USB. Only one state can be installed at a time. See <a href="https://librescoot.org/docs/features/offline-navigation.html">offline navigation</a> for setup instructions.</p>

                <div class="map-table">
                    {% for state in maps.states %}
                        <div class="map-row">
                            <span class="map-name">{{ state.name }}</span>
                            {% if state.osm %}
                                <a href="{{ state.osm.url }}" class="map-btn" title="Map tiles for {{ state.name }}">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 7 6-3 6 3 6-3v13l-6 3-6-3-6 3Z"/><path d="m9 4v13"/><path d="m15 7v13"/></svg>
                                    Map Tiles ({{ state.osm.size | fmt }})
                                </a>
                            {% endif %}
                            {% if state.valhalla %}
                                <a href="{{ state.valhalla.url }}" class="map-btn" title="Routing data for {{ state.name }}">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                                    Routing Data ({{ state.valhalla.size | fmt }})
                                </a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
                <p class="map-source">Source: <a href="https://github.com/librescoot/osm-tiles" target="_blank" rel="noopener">osm-tiles</a>, <a href="https://github.com/librescoot/valhalla-tiles" target="_blank" rel="noopener">valhalla-tiles</a></p>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container footer-inner">
            <span><strong>LibreScoot</strong> &mdash; Open-source firmware for unu Scooter Pro. Not affiliated with unu GmbH.</span>
            <div class="footer-links">
                <a href="https://github.com/librescoot">GitHub</a>
                <a href="https://discord.gg/VrumFruSzJ">Discord</a>
                <a href="https://librescoot.org">Home</a>
            </div>
        </div>
    </footer>

    <script>
    (function() {
        var btn = document.querySelector('.theme-toggle');
        if (!btn) return;
        function getTheme() {
            var stored = localStorage.getItem('theme');
            if (stored) return stored;
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        btn.addEventListener('click', function() {
            var current = getTheme();
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
        });
    })();
    </script>
</body>
</html>
